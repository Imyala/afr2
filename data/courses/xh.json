      "level": "Beginner",
      "lessons": [
        {
          "id": "xh-u1-l1",
          "title": "Greetings",
          "culturalNote": "isiXhosa is famous for its three click sounds: c (dental), x (lateral), and q (palatal). Greet one person with \"Molo\" and a group with \"Molweni\".",
          "vocab": [
            {
              "id": "xh-molo",
              "term": "Molo",
              "translation": "Hello",
              "phonetic": "MOH-loh",
              "note": "to one person"
            },
            {
              "id": "xh-molweni",
              "term": "Molweni",
              "translation": "Hello (everyone)",
              "phonetic": "mohl-WEH-nee",
              "note": "to a group"
            },
            {
              "id": "xh-unjani",
              "term": "Unjani?",
              "translation": "How are you?",
              "phonetic": "oon-JAH-nee"
            },
            {
              "id": "xh-ndiphilile",
              "term": "Ndiphilile",
              "translation": "I am well",
              "phonetic": "ndee-pee-LEE-leh"
            },
            {
              "id": "xh-wena",
              "term": "Wena?",
              "translation": "And you?",
              "phonetic": "WEH-nah"
            },
            {
              "id": "xh-hambakakuhle",
              "term": "Hamba kakuhle",
              "translation": "Go well (goodbye)",
              "phonetic": "HAM-bah kah-KOO-shleh"
            },
            {
              "id": "xh-salakakuhle",
              "term": "Sala kakuhle",
              "translation": "Stay well (goodbye)",
              "phonetic": "SAH-lah kah-KOO-shleh"
            }
          ],
          "exercises": [
            {
              "type": "match",
              "pairs": [
                [
                  "Molo",
                  "Hello"
                ],
                [
                  "Unjani?",
                  "How are you?"
                ],
                [
                  "Ndiphilile",
                  "I am well"
                ],
                [
                  "Wena?",
                  "And you?"
                ]
              ]
            },
            {
              "type": "multiple_choice",
              "prompt": "\"Molo\" means:",
              "answer": "Hello",
              "options": [
                "Goodbye",
                "Hello",
                "Thank you",
                "Yes"
              ],
              "vocabId": "xh-molo"
            },
            {
              "type": "multiple_choice",
              "prompt": "How do you greet a group of people?",
