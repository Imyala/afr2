    {
      "id": "xh-u2",
      "title": "Unit 2: Conversation",
      "level": "Basic Conversation",
      "lessons": [
        {
          "id": "xh-u2-l1",
          "title": "Introducing Yourself",
          "culturalNote": "Xhosa greetings build trust quickly. 'Igama lam ngu...' means 'My name is...'. 'Ndiyavuya ukukwazi' is 'Nice to meet you'.",
          "vocab": [
            {
              "id": "xh-igamalam",
              "term": "Igama lam ngu...",
              "translation": "My name is...",
              "phonetic": "ee-GAH-mah lahm ngoo"
            },
            {
              "id": "xh-ngubani",
              "term": "Ngubani igama lakho?",
              "translation": "What is your name?",
              "phonetic": "ngoo-BAH-nee ee-GAH-mah LAH-koh"
            },
            {
              "id": "xh-ndiyavuya",
              "term": "Ndiyavuya ukukwazi",
              "translation": "Nice to meet you",
              "phonetic": "ndee-yah-VOO-yah oo-koo-KWAH-zee"
            },
            {
              "id": "xh-uvelaphi",
              "term": "Uvela phi?",
              "translation": "Where are you from?",
              "phonetic": "oo-VEH-lah pee"
            },
            {
              "id": "xh-ndivela",
              "term": "Ndivela e...",
              "translation": "I am from...",
              "phonetic": "ndee-VEH-lah eh"
            }
          ],
          "exercises": [
            {
              "type": "match",
              "pairs": [
                [
