                  "My name is..."
                ],
                [
                  "Ngubani igama lakho?",
                  "What is your name?"
                ],
                [
                  "Ndiyavuya ukukwazi",
                  "Nice to meet you"
                ],
                [
                  "Uvela phi?",
                  "Where are you from?"
                ]
              ]
            },
            {
              "type": "multiple_choice",
              "prompt": "“Igama lam ngu...” means:",
              "answer": "My name is...",
              "options": [
                "My name is...",
                "What is your name?",
                "Nice to meet you",
                "Where are you from?"
              ],
              "vocabId": "xh-igamalam"
            },
            {
              "type": "multiple_choice",
              "prompt": "How do you say “What is your name?”?",
