              "prompt": "I am well",
              "answer": "Ndiphilile",
              "accept": [
                "ndiphilile"
              ],
              "vocabId": "xh-ndiphilile"
            },
            {
              "type": "fill_blank",
              "sentence": "____, unjani?",
              "answer": "Molo",
              "options": [
                "Molo",
                "Hayi",
                "Enkosi",
