        {
          "id": "xh-u1-l2",
          "title": "Yes, No & Politeness",
          "culturalNote": "\"Enkosi\" (thank you) is one of the most important words you'll learn. \"Uxolo\" means both \"sorry\" and \"excuse me\".",
          "vocab": [
            {
              "id": "xh-ewe",
              "term": "Ewe",
              "translation": "Yes",
              "phonetic": "EH-weh"
            },
            {
              "id": "xh-hayi",
              "term": "Hayi",
              "translation": "No",
              "phonetic": "HAH-yee"
            },
            {
              "id": "xh-enkosi",
              "term": "Enkosi",
              "translation": "Thank you",
              "phonetic": "en-KOH-see"
            },
            {
              "id": "xh-ndicela",
              "term": "Ndicela",
              "translation": "Please / I request",
              "phonetic": "ndee-CEH-lah"
            },
            {
              "id": "xh-uxolo",
              "term": "Uxolo",
              "translation": "Sorry / Excuse me",
              "phonetic": "oo-KLOH-loh",
              "note": "'x' is a lateral click"
            }
          ],
          "exercises": [
            {
              "type": "match",
              "pairs": [
                [
                  "Ewe",
                  "Yes"
                ],
                [
                  "Hayi",
                  "No"
