                [
                  "Enkosi",
                  "Thank you"
                ],
                [
                  "Uxolo",
                  "Sorry"
                ]
              ]
            },
            {
              "type": "multiple_choice",
              "prompt": "How do you say \"thank you\"?",
              "answer": "Enkosi",
              "options": [
                "Ndicela",
                "Enkosi",
                "Ewe",
                "Hayi"
              ],
              "vocabId": "xh-enkosi"
            },
            {
              "type": "multiple_choice",
              "prompt": "\"Hayi\" means:",
              "answer": "No",
              "options": [
                "Yes",
                "No",
                "Please",
                "Sorry"
              ],
              "vocabId": "xh-hayi"
            },
            {
              "type": "translate",
              "prompt": "Thank you",
              "answer": "Enkosi",
              "accept": [
                "enkosi"
              ],
              "vocabId": "xh-enkosi"
            },
            {
              "type": "fill_blank",
              "sentence": "____, ndicela amanzi.",
              "answer": "Uxolo",
              "options": [
                "Uxolo",
                "Ewe",
                "Hayi",
                "Hamba"
              ],
              "meaning": "Excuse me, may I have water.",
              "vocabId": "xh-uxolo"
            },
            {
              "type": "speak",
              "text": "Enkosi kakhulu",
              "meaning": "Thank you very much",
              "lang": "xh"
            }
          ]
        },
        {
          "id": "xh-u1-l3",
