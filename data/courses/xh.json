{
  "code": "xh",
  "name": "isiXhosa",
  "englishName": "Xhosa",
  "units": [
    {
      "id": "xh-u1",
      "title": "Unit 1: Basics",
      "level": "Beginner",
      "lessons": [
        {
          "id": "xh-u1-l1",
          "title": "Greetings",
          "culturalNote": "isiXhosa is famous for its three click sounds: c (dental), x (lateral), and q (palatal). Greet one person with \"Molo\" and a group with \"Molweni\".",
          "vocab": [
            {"id": "xh-molo", "term": "Molo", "translation": "Hello", "phonetic": "MOH-loh", "note": "to one person"},
            {"id": "xh-molweni", "term": "Molweni", "translation": "Hello (everyone)", "phonetic": "mohl-WEH-nee", "note": "to a group"},
            {"id": "xh-unjani", "term": "Unjani?", "translation": "How are you?", "phonetic": "oon-JAH-nee"},
            {"id": "xh-ndiphilile", "term": "Ndiphilile", "translation": "I am well", "phonetic": "ndee-pee-LEE-leh"},
            {"id": "xh-wena", "term": "Wena?", "translation": "And you?", "phonetic": "WEH-nah"},
            {"id": "xh-hambakakuhle", "term": "Hamba kakuhle", "translation": "Go well (goodbye)", "phonetic": "HAM-bah kah-KOO-shleh"},
            {"id": "xh-salakakuhle", "term": "Sala kakuhle", "translation": "Stay well (goodbye)", "phonetic": "SAH-lah kah-KOO-shleh"}
          ],
          "exercises": [
            {"type": "match", "pairs": [["Molo", "Hello"], ["Unjani?", "How are you?"], ["Ndiphilile", "I am well"], ["Wena?", "And you?"]]},
            {"type": "multiple_choice", "prompt": "\"Molo\" means:", "answer": "Hello", "options": ["Goodbye", "Hello", "Thank you", "Yes"], "vocabId": "xh-molo"},
            {"type": "multiple_choice", "prompt": "How do you greet a group of people?", "answer": "Molweni", "options": ["Molo", "Molweni", "Wena", "Unjani"], "vocabId": "xh-molweni"},
            {"type": "translate", "prompt": "I am well", "answer": "Ndiphilile", "accept": ["ndiphilile"], "vocabId": "xh-ndiphilile"},
            {"type": "fill_blank", "sentence": "____, unjani?", "answer": "Molo", "options": ["Molo", "Hayi", "Enkosi", "Wena"], "meaning": "Hello, how are you?", "vocabId": "xh-molo"},
            {"type": "listen", "prompt": "Tap what you hear", "answer": "Ndiphilile", "options": ["Ndiphilile", "Molo", "Unjani", "Wena"], "lang": "xh", "vocabId": "xh-ndiphilile"},
            {"type": "speak", "text": "Ndiphilile, wena?", "meaning": "I am well, and you?", "lang": "xh"}
          ]
        },
        {
          "id": "xh-u1-l2",
          "title": "Yes, No & Politeness",
          "culturalNote": "\"Enkosi\" (thank you) is one of the most important words you'll learn. \"Uxolo\" means both \"sorry\" and \"excuse me\".",
          "vocab": [
            {"id": "xh-ewe", "term": "Ewe", "translation": "Yes", "phonetic": "EH-weh"},
            {"id": "xh-hayi", "term": "Hayi", "translation": "No", "phonetic": "HAH-yee"},
            {"id": "xh-enkosi", "term": "Enkosi", "translation": "Thank you", "phonetic": "en-KOH-see"},
            {"id": "xh-ndicela", "term": "Ndicela", "translation": "Please / I request", "phonetic": "ndee-CEH-lah"},
            {"id": "xh-uxolo", "term": "Uxolo", "translation": "Sorry / Excuse me", "phonetic": "oo-KLOH-loh", "note": "'x' is a lateral click"}
          ],
          "exercises": [
            {"type": "match", "pairs": [["Ewe", "Yes"], ["Hayi", "No"], ["Enkosi", "Thank you"], ["Uxolo", "Sorry"]]},
            {"type": "multiple_choice", "prompt": "How do you say \"thank you\"?", "answer": "Enkosi", "options": ["Ndicela", "Enkosi", "Ewe", "Hayi"], "vocabId": "xh-enkosi"},
            {"type": "multiple_choice", "prompt": "\"Hayi\" means:", "answer": "No", "options": ["Yes", "No", "Please", "Sorry"], "vocabId": "xh-hayi"},
            {"type": "translate", "prompt": "Thank you", "answer": "Enkosi", "accept": ["enkosi"], "vocabId": "xh-enkosi"},
            {"type": "fill_blank", "sentence": "____, ndicela amanzi.", "answer": "Uxolo", "options": ["Uxolo", "Ewe", "Hayi", "Hamba"], "meaning": "Excuse me, may I have water.", "vocabId": "xh-uxolo"},
            {"type": "speak", "text": "Enkosi kakhulu", "meaning": "Thank you very much", "lang": "xh"}
          ]
        },
        {
          "id": "xh-u1-l3",
          "title": "Family & Respect",
          "culturalNote": "As in Zulu, you show respect by addressing elders as \"Tata\" (father) or \"Mama\" (mother). Mandela was affectionately called \"Tata\" by the nation.",
          "vocab": [
            {"id": "xh-umama", "term": "umama", "translation": "mother", "phonetic": "oo-MAH-mah"},
            {"id": "xh-utata", "term": "utata", "translation": "father", "phonetic": "oo-TAH-tah"},
            {"id": "xh-usisi", "term": "usisi", "translation": "sister", "phonetic": "oo-SEE-see"},
            {"id": "xh-ubhuti", "term": "ubhuti", "translation": "brother", "phonetic": "oo-BOO-tee"},
            {"id": "xh-umakhulu", "term": "umakhulu", "translation": "grandmother", "phonetic": "oo-mah-KOO-loo"},
            {"id": "xh-utatomkhulu", "term": "utatomkhulu", "translation": "grandfather", "phonetic": "oo-tah-toh-MKOO-loo"},
            {"id": "xh-umntwana", "term": "umntwana", "translation": "child", "phonetic": "oom-TWAH-nah"}
          ],
          "exercises": [
            {"type": "match", "pairs": [["umama", "mother"], ["utata", "father"], ["umakhulu", "grandmother"], ["umntwana", "child"]]},
            {"type": "multiple_choice", "prompt": "How do you respectfully address an older man?", "answer": "Tata", "options": ["Tata", "Sisi", "Umntwana", "Hayi"], "vocabId": "xh-utata"},
            {"type": "translate", "prompt": "mother", "answer": "umama", "accept": ["umama", "mama"], "vocabId": "xh-umama"},
            {"type": "fill_blank", "sentence": "Lo ____ uneminyaka emihlanu.", "answer": "mntwana", "options": ["mntwana", "makhulu", "tata", "sisi"], "meaning": "This child is five years old.", "vocabId": "xh-umntwana"},
            {"type": "listen", "prompt": "Tap what you hear", "answer": "utata", "options": ["utata", "umama", "usisi", "ubhuti"], "lang": "xh", "vocabId": "xh-utata"}
          ]
        },
        {
          "id": "xh-u1-l4",
          "title": "Numbers 1–10",
          "culturalNote": "Like Zulu, Xhosa numbers change shape with the noun they count. These are common counting forms used by learners.",
          "vocab": [
            {"id": "xh-inye", "term": "inye", "translation": "one", "phonetic": "EE-nyeh"},
            {"id": "xh-isibini", "term": "isibini", "translation": "two", "phonetic": "ee-see-BEE-nee"},
            {"id": "xh-isithathu", "term": "isithathu", "translation": "three", "phonetic": "ee-see-TAH-too"},
            {"id": "xh-isine", "term": "isine", "translation": "four", "phonetic": "ee-SEE-neh"},
            {"id": "xh-isihlanu", "term": "isihlanu", "translation": "five", "phonetic": "ee-see-SHLAH-noo"},
            {"id": "xh-isithandathu", "term": "isithandathu", "translation": "six", "phonetic": "ee-see-tahn-DAH-too"},
            {"id": "xh-ishumi", "term": "ishumi", "translation": "ten", "phonetic": "ee-SHOO-mee"}
          ],
          "exercises": [
            {"type": "match", "pairs": [["inye", "one"], ["isibini", "two"], ["isithathu", "three"], ["isihlanu", "five"]]},
            {"type": "multiple_choice", "prompt": "How do you say \"five\"?", "answer": "isihlanu", "options": ["isine", "isihlanu", "isibini", "ishumi"], "vocabId": "xh-isihlanu"},
            {"type": "translate", "prompt": "three", "answer": "isithathu", "accept": ["isithathu"], "vocabId": "xh-isithathu"},
            {"type": "fill_blank", "sentence": "Ndicela ii-orenji ezi____.", "answer": "isibini", "options": ["isibini", "inye", "ishumi", "isine"], "meaning": "Please give me two oranges.", "vocabId": "xh-isibini"},
            {"type": "listen", "prompt": "Tap the number you hear", "answer": "ishumi", "options": ["ishumi", "inye", "isine", "isihlanu"], "lang": "xh", "vocabId": "xh-ishumi"}
          ]
        },
        {
          "id": "xh-u1-l5",
          "title": "Food & Drink",
          "culturalNote": "Offering food and drink is a sign of welcome. \"Ndicela amanzi\" (please may I have water) is a polite, useful phrase.",
          "vocab": [
            {"id": "xh-ukutya", "term": "ukutya", "translation": "food", "phonetic": "oo-KOO-tyah"},
            {"id": "xh-amanzi", "term": "amanzi", "translation": "water", "phonetic": "ah-MAN-zee"},
            {"id": "xh-isonka", "term": "isonka", "translation": "bread", "phonetic": "ee-SOHN-kah"},
            {"id": "xh-ubisi", "term": "ubisi", "translation": "milk", "phonetic": "oo-BEE-see"},
            {"id": "xh-iti", "term": "iti", "translation": "tea", "phonetic": "EE-tee"},
            {"id": "xh-inyama", "term": "inyama", "translation": "meat", "phonetic": "in-YAH-mah"}
          ],
          "exercises": [
            {"type": "match", "pairs": [["amanzi", "water"], ["isonka", "bread"], ["ubisi", "milk"], ["inyama", "meat"]]},
            {"type": "multiple_choice", "prompt": "How do you say \"water\"?", "answer": "amanzi", "options": ["ubisi", "amanzi", "iti", "ukutya"], "vocabId": "xh-amanzi"},
            {"type": "multiple_choice", "prompt": "\"ukutya\" means:", "answer": "food", "options": ["food", "drink", "bread", "meat"], "vocabId": "xh-ukutya"},
            {"type": "translate", "prompt": "water", "answer": "amanzi", "accept": ["amanzi"], "vocabId": "xh-amanzi"},
            {"type": "fill_blank", "sentence": "Ndicela ____ nesonka.", "answer": "iti", "options": ["iti", "inyama", "amanzi", "umntwana"], "meaning": "Please may I have tea and bread.", "vocabId": "xh-iti"},
            {"type": "speak", "text": "Ndicela amanzi", "meaning": "Please may I have water", "lang": "xh"}
          ]
        },
        {
          "id": "xh-u1-l6",
          "title": "Directions",
          "culturalNote": "Begin with \"Uxolo\" (excuse me) when asking for directions. \"Ekunene\" is right and \"ekhohlo\" is left.",
          "vocab": [
            {"id": "xh-phambili", "term": "phambili", "translation": "forward / ahead", "phonetic": "pam-BEE-lee"},
            {"id": "xh-emva", "term": "emva", "translation": "behind / back", "phonetic": "EM-vah"},
            {"id": "xh-ekunene", "term": "ekunene", "translation": "right", "phonetic": "eh-koo-NEH-neh"},
            {"id": "xh-ekhohlo", "term": "ekhohlo", "translation": "left", "phonetic": "eh-KOH-shloh"},
            {"id": "xh-apha", "term": "apha", "translation": "here", "phonetic": "AH-pah"},
            {"id": "xh-kufuphi", "term": "kufuphi", "translation": "near", "phonetic": "koo-FOO-pee"},
            {"id": "xh-kude", "term": "kude", "translation": "far", "phonetic": "KOO-deh"}
          ],
          "exercises": [
            {"type": "match", "pairs": [["phambili", "ahead"], ["ekunene", "right"], ["ekhohlo", "left"], ["kude", "far"]]},
            {"type": "multiple_choice", "prompt": "How do you say \"turn right\"? (right =)", "answer": "ekunene", "options": ["ekhohlo", "ekunene", "phambili", "emva"], "vocabId": "xh-ekunene"},
            {"type": "multiple_choice", "prompt": "\"kufuphi\" means:", "answer": "near", "options": ["far", "near", "left", "behind"], "vocabId": "xh-kufuphi"},
            {"type": "translate", "prompt": "here", "answer": "apha", "accept": ["apha"], "vocabId": "xh-apha"},
            {"type": "fill_blank", "sentence": "Ivenkile i____ kakhulu.", "answer": "kude", "options": ["kude", "kufuphi", "apha", "phambili"], "meaning": "The shop is very far.", "vocabId": "xh-kude"}
          ]
        }
      ]
    }
  ],
  "reading": [
    {
      "id": "xh-r1",
      "title": "Molo, Lindiwe!",
      "level": "Beginner",
      "intro": "Two friends greet each other. Tap any line to hear it.",
      "lines": [
        {"t": "Molo, igama lam nguLindiwe.", "en": "Hello, my name is Lindiwe."},
        {"t": "Molo Lindiwe. Igama lam nguAyanda.", "en": "Hello Lindiwe. My name is Ayanda."},
        {"t": "Unjani namhlanje?", "en": "How are you today?"},
        {"t": "Ndiphilile, enkosi. Wena?", "en": "I am well, thank you. And you?"},
        {"t": "Nam ndiphilile. Hamba kakuhle!", "en": "I am also well. Go well!"}
      ],
      "questions": [
        {"type": "multiple_choice", "prompt": "What is the girl's name?", "answer": "Lindiwe", "options": ["Lindiwe", "Ayanda", "Nandi", "Mama"]},
        {"type": "multiple_choice", "prompt": "How does Ayanda feel?", "answer": "Well", "options": ["Well", "Tired", "Sad", "Lost"]},
        {"type": "translate", "prompt": "Thank you", "answer": "Enkosi", "accept": ["enkosi"], "vocabId": "xh-enkosi"}
      ]
    }
  ]
}
